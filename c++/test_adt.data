QLENGTH

# ============================================
# ТЕСТ ДЕРЕВА (только целые числа!)
# ============================================
CLEAR T
TINSERT 5
TINSERT 3
TINSERT 7
TINSERT 2
TINSERT 4
TINSERT 6
TINSERT 8
PRINT T
TGET 4
TGET 9
TDEL 7
PRINT T
TDEL 3
PRINT T

